#!/bin/bash

ARCEUS_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_PYTHON="$ARCEUS_DIR/venv/bin/python"
SESSION="arceus"

# Set tmux key bindings (both uppercase and lowercase)
cat > ~/.tmux.conf << 'TMUX'
bind H previous-window
bind h previous-window
bind Z detach
bind z detach
bind N next-window
bind n next-window
TMUX

# Kill existing session if any
tmux kill-session -t $SESSION 2>/dev/null

# Create session with cv.py in first window (background)
tmux new-session -d -s $SESSION -n cv
tmux send-keys -t $SESSION:cv "$VENV_PYTHON $ARCEUS_DIR/cv.py" Enter

# Create second window for nlp.py (background)
tmux new-window -t $SESSION -n nlp
tmux send-keys -t $SESSION:nlp "$VENV_PYTHON $ARCEUS_DIR/nlp.py" Enter

echo "[INFO] cv.py and nlp.py are running in background."
echo ""
echo "  Ctrl+B then N/n  →  go to nlp"
echo "  Ctrl+B then H/h  →  go to cv"
echo "  Ctrl+B then Z/z  →  back to control terminal"
echo ""
echo "[INFO] Type 'cv' or 'nlp' to jump directly."
